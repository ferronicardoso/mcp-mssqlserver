{
  "name": "mcp-mssqlserver",
  "version": "1.0.0",
  "description": "MCP server para interação com SQL Server via linguagem natural",
  "type": "module",
  "bin": {
    "mcp-mssqlserver": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "hooks:install": "husky",
    "precommit:build": "npm run build && git add dist",
    "start": "node dist/index.js",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "fast-xml-parser": "^5.9.3",
    "msnodesqlv8": "^5.1.1",
    "mssql": "^11.0.1"
  },
  "devDependencies": {
    "@types/mssql": "^9.1.5",
    "@types/node": "^22.0.0",
    "husky": "^9.1.7",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18"
  }
}
